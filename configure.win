#!/bin/sh
if ! command -v zig >/dev/null 2>&1; then
  echo "could not find Zig"
  exit 1
fi
printf "using Zig "
zig version

: ${ZIG_JOBS:=1}
: ${ZIG_CPU:=baseline}
: ${ZIG_OPTIMIZE:=ReleaseFast}
: ${ZIG_STRIP:=false}

cd src && SHLIB_EXT=$("${R_HOME}/bin/R" CMD config SHLIB_EXT) \
  "${R_HOME}/bin/R" CMD zig build -p . \
  -j"${ZIG_JOBS}" \
  -Dcpu="${ZIG_CPU}" \
  -Doptimize="${ZIG_OPTIMIZE}" \
  -Dstrip="${ZIG_STRIP}"
